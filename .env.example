# PoliTech API (backend из репозитория PtDocker)
POLITECH_API_URL=http://host.docker.internal:8080

# Tenant и сервисная учётка для BFF (не попадает в браузер)
TENANT_CODE=demo
SERVICE_USER_LOGIN=demo
SERVICE_PASSWORD=demo
SERVICE_CLIENT_ID=sys

# Порт публичного фронта
FASTID_FRONT_PORT=8082

# Docker Hub (production — один образ, docker-compose-published.yml)
APP_IMAGE=olegsirik/fastid:latest

# Rate limits (запросов в минуту на IP)
RATE_LIMIT_PREMIUM=10
RATE_LIMIT_DECRYPT=20
RATE_LIMIT_SECURE_LINK=10

# Шифрование QR / secure-link (локально в BFF, не PoliTech)
FASTID_SECURE_LINK_SECRET=change-me-in-production
